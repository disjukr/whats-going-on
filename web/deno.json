{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A npm:vite@^6.0.0 --host 0.0.0.0",
    "build": "deno run -A npm:typescript@^5.9.0/tsc -b && deno run -A npm:vite@^6.0.0 build",
    "check": "deno task check:tools && deno run -A npm:typescript@^5.9.0/tsc -b",
    "check:daemon": "deno run --unstable-net --allow-net --allow-read=.. src/tools/check-daemon.ts",
    "check:tools": "deno check --unstable-net src/tools/check-daemon.ts",
    "preview": "deno run -A npm:vite@^6.0.0 preview --host 0.0.0.0"
  },
  "imports": {
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4.3.4",
    "bunja": "npm:bunja@^3.0.0",
    "bunja/react": "npm:bunja@^3.0.0/react",
    "jotai": "npm:jotai@^2.15.0",
    "jotai/utils": "npm:jotai@^2.15.0/utils",
    "lucide-react": "npm:lucide-react@^0.468.0",
    "monaco-editor": "npm:monaco-editor@0.55.1",
    "monaco-editor/esm/vs/editor/editor.api.js": "npm:monaco-editor@0.55.1/esm/vs/editor/editor.api.js",
    "monaco-editor/esm/vs/editor/editor.worker.js": "npm:monaco-editor@0.55.1/esm/vs/editor/editor.worker.js",
    "monaco-editor/esm/vs/language/css/css.worker.js": "npm:monaco-editor@0.55.1/esm/vs/language/css/css.worker.js",
    "monaco-editor/esm/vs/language/html/html.worker.js": "npm:monaco-editor@0.55.1/esm/vs/language/html/html.worker.js",
    "monaco-editor/esm/vs/language/json/json.worker.js": "npm:monaco-editor@0.55.1/esm/vs/language/json/json.worker.js",
    "monaco-editor/esm/vs/language/typescript/ts.worker.js": "npm:monaco-editor@0.55.1/esm/vs/language/typescript/ts.worker.js",
    "panecake": "npm:panecake@^0.0.1",
    "react": "npm:react@^19.0.0",
    "react/jsx-dev-runtime": "npm:react@^19.0.0/jsx-dev-runtime",
    "react/jsx-runtime": "npm:react@^19.0.0/jsx-runtime",
    "react-dom": "npm:react-dom@^19.0.0",
    "react-dom/client": "npm:react-dom@^19.0.0/client",
    "vite": "npm:vite@^6.0.0"
  }
}
